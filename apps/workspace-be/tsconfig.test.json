// tests/tsconfig.json
{
  "compilerOptions": {
    "rootDir": "..",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2022",
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": false
  },
  "include": ["./**/*", "../src/**/*"]
}